# PostgreSQL connection string (get from Neon / Vercel Postgres / Supabase)
DATABASE_URL='postgresql://user:password@host:5432/dbname?connect_timeout=15'

# NextAuth
NEXTAUTH_SECRET='generate-with: openssl rand -base64 32'
NEXTAUTH_URL='https://your-domain.com'

# Resend (https://resend.com) - for password reset & feedback emails
RESEND_API_KEY='re_your_api_key'
EMAIL_FROM='CountdownDo <noreply@your-domain.com>'
FEEDBACK_NOTIFICATION_EMAIL='you@example.com'

# Optional: Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=''
