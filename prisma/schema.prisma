generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  hashedPassword    String
  resetToken        String?
  resetTokenExpiry  DateTime?
  // Bumped on password reset to invalidate any existing sessions (e.g. an
  // attacker's, if that's why the password was reset) — see lib/auth.ts.
  tokenVersion      Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  activeSession     ActiveSession?
  completionLogs    CompletionLog[]
  bankTasks         BankTask[]
  bankTaskTemplates BankTaskTemplate[]
}

model BankTask {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  durationSeconds Int
  color           String   // TaskColorId: orange, blue, green, purple, pink
  tags            String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model BankTaskTemplate {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String   // template label, e.g. "Household Chore"
  durationSeconds Int
  color           String
  tags            String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  scope     String   // e.g. 'signup:ip', 'forgot-password:ip', 'forgot-password:email'
  keyHash   String   // sha256 hash of the IP or email being limited
  createdAt DateTime @default(now())

  @@index([scope, keyHash, createdAt])
}

model Feedback {
  id        String   @id @default(cuid())
  category  String   // 'bug' | 'feature' | 'general'
  message   String
  email     String?  // optional reply-to email
  ipHash    String   // hashed IP for rate limiting
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
}

model CompletionLog {
  id              String   @id @default(cuid())
  taskName        String
  durationSeconds Int
  color           String?  // TaskColorId: orange, blue, green, purple, pink
  completedAt     DateTime @default(now())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
}

model ActiveSession {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks               Json     // Full task array with state
  sessionState        String   // 'idle' | 'running' | 'paused' — 'idle' is a staged, not-yet-started task list
  sessionMode         String   @default("continuous") // 'continuous' | 'sprint'
  sessionStartMs      Float    // Date.now() when session started/resumed
  pausedElapsed       Float    // seconds elapsed before last pause
  sessionTotalSeconds Float    @default(0) // Total session duration envelope (continuous mode)
  soundPlayed         Json     @default("[]") // array of task IDs whose sound has played
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
